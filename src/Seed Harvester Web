<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yoga Fire | Seed Harvester</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; background-color: #050505; color: #e5e7eb; font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }
        .glass { background: rgba(15, 15, 15, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        input::placeholder { color: #4b5563; }
        .custom-scroll::-webkit-scrollbar { width: 4px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #ea580c; border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 flex flex-col items-center">

    <div class="w-full max-w-4xl space-y-6">
        <!-- Header -->
        <header class="flex justify-between items-center glass p-6 rounded-2xl">
            <div>
                <h1 class="text-2xl font-black tracking-tighter text-orange-500 uppercase italic">Yoga Fire</h1>
                <p class="text-[10px] font-mono text-gray-400 uppercase tracking-widest">Seed Harvester v1.0</p>
            </div>
            <div class="text-right">
                <span class="text-xs font-mono text-green-400 bg-green-950/30 px-2 py-1 rounded">CORS PROXY: ACTIVE</span>
            </div>
        </header>

        <!-- Search Bar -->
        <section class="glass p-6 rounded-2xl flex gap-4">
            <input type="text" id="search-input" placeholder="Search Mineral (e.g., Quartz, Beryl, Diamond)..." 
                   class="flex-1 bg-black/50 border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-orange-500 transition-all font-mono text-sm">
            <button id="search-btn" class="bg-orange-600 hover:bg-orange-500 px-8 py-3 rounded-xl font-bold transition-all text-sm">HARVEST</button>
        </section>

        <!-- Main Display -->
        <main class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Results List -->
            <div class="md:col-span-1 glass rounded-2xl overflow-hidden flex flex-col h-[600px]">
                <div class="p-4 border-b border-white/10 bg-white/5 font-mono text-[10px] uppercase tracking-widest text-gray-400">COD Search Results</div>
                <div id="results-list" class="flex-1 overflow-y-auto custom-scroll p-2 space-y-2">
                    <div class="p-4 text-center text-gray-600 text-xs italic mt-20">No seeds harvested yet.</div>
                </div>
            </div>

            <!-- Seed Preview -->
            <div class="md:col-span-2 glass rounded-2xl overflow-hidden flex flex-col h-[600px]">
                <div class="p-4 border-b border-white/10 bg-white/5 flex justify-between items-center">
                    <span class="font-mono text-[10px] uppercase tracking-widest text-gray-400 italic">Seed DNA Preview</span>
                    <button id="download-btn" class="hidden text-[10px] font-bold bg-green-600 hover:bg-green-500 text-white px-3 py-1 rounded uppercase transition-all">Download .json</button>
                </div>
                <pre id="seed-preview" class="flex-1 p-6 font-mono text-[11px] overflow-auto text-orange-400/80 leading-relaxed custom-scroll">
// Select a seed to view its Material DNA...
                </pre>
            </div>
        </main>
    </div>

    <script type="module">
        const searchInput = document.getElementById('search-input');
        const searchBtn = document.getElementById('search-btn');
        const resultsList = document.getElementById('results-list');
        const seedPreview = document.getElementById('seed-preview');
        const downloadBtn = document.getElementById('download-btn');

        // Proxy to bypass CORS
        const PROXY = "https://api.allorigins.win/raw?url=";
        const COD_BASE = "https://www.crystallography.net/cod";

        // Material Estimation Table
        const PROPERTY_LOOKUP = {
            "SiO2": { n: 1.544, rho: 2.65, E: 95.0 },
            "Al2O3": { n: 1.768, rho: 3.98, E: 400.0 },
            "C": { n: 2.417, rho: 3.51, E: 1220.0 },
            "Be3Al2Si6O18": { n: 1.577, rho: 2.76, E: 220.0 },
            "CaCO3": { n: 1.658, rho: 2.71, E: 73.0 }
        };

        let currentSeed = null;

        searchBtn.onclick = async () => {
            const query = searchInput.value.trim();
            if (!query) return;

            searchBtn.disabled = true;
            searchBtn.textContent = "SEARCHING...";
            resultsList.innerHTML = '<div class="p-4 text-center text-orange-500 animate-pulse text-xs">Accessing Vault...</div>';

            try {
                const searchUrl = encodeURIComponent(`${COD_BASE}/result.json?text=${query}`);
                const response = await fetch(`${PROXY}${searchUrl}`);
                const data = await response.json();
                
                renderResults(data);
            } catch (err) {
                resultsList.innerHTML = `<div class="p-4 text-red-500 text-xs">Error: ${err.message}</div>`;
            } finally {
                searchBtn.disabled = false;
                searchBtn.textContent = "HARVEST";
            }
        };

        function renderResults(data) {
            resultsList.innerHTML = '';
            if (!data || data.length === 0) {
                resultsList.innerHTML = '<div class="p-4 text-gray-500 text-xs italic">No minerals found.</div>';
                return;
            }

            data.slice(0, 20).forEach(item => {
                const el = document.createElement('div');
                el.className = "p-3 glass hover:bg-orange-600/20 cursor-pointer rounded-xl border-white/5 transition-all group";
                el.innerHTML = `
                    <div class="text-[10px] font-mono text-orange-500 mb-1">COD: ${item.file}</div>
                    <div class="text-xs font-bold text-gray-300 truncate group-hover:text-white">${item.formula || 'Unknown Formula'}</div>
                `;
                el.onclick = () => harvestCIF(item.file);
                resultsList.appendChild(el);
            });
        }

        async function harvestCIF(id) {
            seedPreview.textContent = "// Harvesting CIF and generating DNA...";
            downloadBtn.classList.add('hidden');

            try {
                const cifUrl = encodeURIComponent(`${COD_BASE}/${id}.cif`);
                const response = await fetch(`${PROXY}${cifUrl}`);
                const text = await response.text();
                
                const seed = parseCIF(id, text);
                currentSeed = seed;
                
                seedPreview.textContent = JSON.stringify(seed, null, 2);
                downloadBtn.classList.remove('hidden');
            } catch (err) {
                seedPreview.textContent = `// Error harvesting seed: ${err.message}`;
            }
        }

        function parseCIF(id, text) {
            const lines = text.split('\n');
            const dna = {
                seed_id: `cod_${id}`,
                metadata: {
                    source: "Crystallography Open Database",
                    cod_id: id,
                    citation: "Unknown",
                    formula: "Unknown"
                },
                material_dna: {
                    mechanical: { bulk_density: 0, youngs_modulus: 0 },
                    optical: { refractive_index_base: 1.0 },
                    acoustic: { phonon_velocity: 0 }
                },
                lattice_logic: { unit_cell: {} }
            };

            const getValue = (line) => parseFloat(line.split(/\s+/).pop().replace(/\(.*\)/, ''));

            lines.forEach(line => {
                if (line.includes('_cell_length_a')) dna.lattice_logic.unit_cell.a = getValue(line);
                if (line.includes('_cell_length_b')) dna.lattice_logic.unit_cell.b = getValue(line);
                if (line.includes('_cell_length_c')) dna.lattice_logic.unit_cell.c = getValue(line);
                if (line.includes('_cell_angle_alpha')) dna.lattice_logic.unit_cell.alpha = getValue(line);
                if (line.includes('_cell_angle_beta')) dna.lattice_logic.unit_cell.beta = getValue(line);
                if (line.includes('_cell_angle_gamma')) dna.lattice_logic.unit_cell.gamma = getValue(line);
                if (line.includes('_chemical_formula_sum')) {
                    const formula = line.replace('_chemical_formula_sum', '').replace(/'/g, '').trim();
                    dna.metadata.formula = formula;
                }
                if (line.includes('_publ_section_title')) {
                    dna.metadata.citation = line.replace('_publ_section_title', '').trim().replace(/^'|'$/g, '');
                }
            });

            // Estimation
            const formula = dna.metadata.formula;
            const props = PROPERTY_LOOKUP[formula] || { n: 1.5, rho: 2.5, E: 70.0 };
            
            dna.material_dna.optical.refractive_index_base = props.n;
            dna.material_dna.mechanical.bulk_density = props.rho;
            dna.material_dna.mechanical.youngs_modulus = props.E;
            dna.material_dna.acoustic.phonon_velocity = Math.round(Math.sqrt(props.E / props.rho) * 1000);

            return dna;
        }

        downloadBtn.onclick = () => {
            if (!currentSeed) return;
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(currentSeed, null, 2));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            downloadAnchorNode.setAttribute("download", `${currentSeed.seed_id}.json`);
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        };
    </script>
</body>
</html>
